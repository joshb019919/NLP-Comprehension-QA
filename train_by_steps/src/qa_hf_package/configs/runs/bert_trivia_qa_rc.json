{
  "model_config_path": "configs/models/bert-base-uncased.json",
  "dataset_config_path": "configs/datasets/trivia_qa_rc.json",
  "output_name": "bert_trivia_qa_rc",
  "streaming": false,
  "torch_compile": true,
  "tokenizer_parallelism": false,
  "force_rebuild_cache": false,
  "process_memory_limit_mb": null,
  "max_length": 384,
  "doc_stride": 64,
  "max_examples": null,
  "preprocessing_num_proc": 8,
  "preprocess_num_chunks": 8,
  "map_batch_size": 128,
  "writer_batch_size": 128,
  "dataloader_num_workers": 8,
  "dataloader_pin_memory": true,
  "dataloader_drop_last": false,
  "learning_rate": 5e-05,
  "batch_size": 70,
  "epochs": 2,
  "lr_scheduler": "cosine",
  "weight_decay": 1e-08,
  "gradient_accumulation_steps": 1,
  "strategy": "epoch",
  "optim": "adamw_torch",
  "gradient_checkpointing": false,
  "max_grad_norm": 1.0,
  "load_best_model_at_end": true,
  "remove_unused_columns": false,
  "report_to": "none",
  "save_total_limit": 5,
  "logging_steps": 20,
  "save_strategy": "steps",
  "save_steps": 200,
  "evaluation_strategy": "steps",
  "eval_steps": 200,
  "metric_for_best_model": "eval_f1",
  "greater_is_better": true,
  "data_root": "/data/data/huggingface",
  "retry_broken_downloads": true,
  "seed": 42
}