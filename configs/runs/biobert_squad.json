{
  "model_config_path": "configs/models/biobert-base-cased-v1.1.json",
  "dataset_config_path": "configs/datasets/squad.json",
  "output_name": "biobert_squad",
  "streaming": false,
  "torch_compile": true,
  "tokenizer_parallelism": false,
  "force_rebuild_cache": false,
  "process_memory_limit_mb": null,
  "max_length": 384,
  "doc_stride": 192,
  "max_examples": null,
  "preprocessing_num_proc": null,
  "preprocess_num_chunks": 8,
  "map_batch_size": 64,
  "writer_batch_size": 64,
  "limit_after_tokenization": true,
  "after_tokenization_limit": null,
  "after_tokenization_train_limit": 20000,
  "after_tokenization_validation_limit": 5000,
  "after_tokenization_test_limit": 5000,
  "dataloader_num_workers": 0,
  "dataloader_pin_memory": true,
  "dataloader_drop_last": false,
  "learning_rate": 5e-05,
  "batch_size": 16,
  "epochs": 2,
  "lr_scheduler": "cosine",
  "weight_decay": 1e-08,
  "gradient_accumulation_steps": 8,
  "strategy": "steps",
  "steps": 50,
  "optim": "adamw_torch",
  "gradient_checkpointing": false,
  "max_grad_norm": 1.0,
  "load_best_model_at_end": true,
  "remove_unused_columns": false,
  "report_to": "none",
  "save_total_limit": 5,
  "logging_steps": 20,
  "metric_for_best_model": "eval_f1",
  "greater_is_better": true,
  "data_root": "/data/data/huggingface",
  "retry_broken_downloads": true,
  "seed": 42
}
